# Example environment variables for local statebound development.
#
# NOTE: docker-compose.yml in this directory does not read this file; it
# uses inline values for Phase 0 so a fresh `make docker-up` works with
# zero setup. This file documents the variables the statebound binary
# itself reads at runtime, plus the Postgres credentials that match the
# compose defaults so you can copy them into your shell environment.
#
# Usage:
#   cp deploy/docker-compose/.env.example .env
#   # then `set -a; source .env; set +a` (bash) or use direnv

# Postgres credentials — these mirror the compose defaults. Change them
# in both places if you customize the database.
POSTGRES_USER=statebound
POSTGRES_PASSWORD=statebound
POSTGRES_DB=statebound

# DSN consumed by the statebound binary (see internal/cli/root.go and
# the --db-dsn persistent flag). Override per-shell or per-deployment.
STATEBOUND_DB_DSN=postgres://statebound:statebound@localhost:5432/statebound?sslmode=disable
