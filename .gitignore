# Binaries built locally.
/bin/
/dist/
/statebound
/statebound-reason

# Go test/build caches when run outside the Docker wrapper.
*.test
*.out
coverage.txt

# Persistent Go module / build caches mounted into the scripts/go.sh
# Docker container. Kept on the host to avoid re-downloading deps every
# run; never committed.
/.gocache/
/.gomodcache/

# Go toolchain local telemetry — written by the Docker-wrapped go binary
# when HOME is set inside the container; not project state.
/.config/

# Local docker-compose volumes / overrides.
/deploy/docker-compose/.data/
/deploy/docker-compose/docker-compose.override.yml

# Editor / OS noise.
.DS_Store
.idea/
.vscode/
*.swp
*~

# Local secrets — Statebound never stores secrets, but contributors may keep
# kubeconfigs, TLS certs, or scratch creds locally. Keep them out of git.
.env
.env.local
*.pem
*.key

# Generated artifacts that should not live in git.
schemas/openapi.gen.go
schemas/*.gen.go
internal/storage/sqlc/

# Rego bundle is synced from policies/builtin/ at build time. The
# authoritative copies live in policies/builtin/; the embed copy is a
# build artifact (see Makefile authz-sync-bundle and the CI workflow).
internal/authz/bundle/*.rego

# Local-only project state.
/.claude/
/.remember/

# (ADRs and CLAUDE.md were tracked in v1.0 once the spec stabilised. They
# previously lived locally during the rename / anonymisation pass — see the
# CHANGELOG for that history.)
